# ─────────────────────────────────────────────────────────────────────────────
# ZnShop — Digital Store Manager
# Copy this file to backend/.env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Server
DEBUG=false
LOG_LEVEL=INFO

# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Redis
REDIS_URL=redis://redis:6379/0

# Ollama (local LLM inference — run `ollama serve` locally)
AI_MODEL_ENDPOINT=http://host.docker.internal:11434/api/generate
AI_MODEL_NAME=mistral

# WhatsApp (Meta Graph API — https://developers.facebook.com)
WHATSAPP_VERIFY_TOKEN=znshop_verify
WHATSAPP_ACCESS_TOKEN=<your-meta-access-token>
WHATSAPP_PHONE_NUMBER_ID=<your-phone-number-id>

# Admin Dashboard Credentials
ADMIN_EMAIL=admin@znshop.local
ADMIN_PASSWORD=<choose-a-strong-password>

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=<your-jwt-secret>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin Dashboard API URL (used when running in Docker)
ZNSHOP_API_URL=http://backend:8000/api/v1

