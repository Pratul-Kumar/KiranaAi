# ZnShop production environment template
# Copy to .env and fill with real secrets/URLs before deployment.

PORT=8000
ADMIN_EMAIL=admin@znshop.local
ADMIN_PASSWORD=changeme
SUPABASE_URL=your_database_url
SUPABASE_KEY=your_database_key
JWT_SECRET=secure_secret_key
REDIS_URL=redis://localhost:6379
OLLAMA_URL=http://localhost:11434

# Optional / recommended
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PASSWORD_HASH=
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=false
LOG_LEVEL=INFO
AI_MODEL_ENDPOINT=
AI_MODEL_NAME=mistral
CORS_ORIGINS=*
WHATSAPP_VERIFY_TOKEN=znshop_verify
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
ZNSHOP_API_URL=https://your-domain.com/api/v1
